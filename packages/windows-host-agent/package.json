{
  "name": "@rikune/windows-host-agent",
  "version": "1.0.0-beta.3",
  "description": "Rikune Windows Host Agent for remote sandbox lifecycle management.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
