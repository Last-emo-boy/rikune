# Rikune Analyzer Environment
# Copy this file to .env and adjust values for your setup.

NODE_ENV=production
NODE_ROLE=analyzer

# Runtime mode: disabled | auto-sandbox | manual | remote-sandbox
RUNTIME_MODE=remote-sandbox

# For remote-sandbox mode (Linux Docker -> Windows Host Agent)
RUNTIME_HOST_AGENT_ENDPOINT=http://windows-host-ip:18082
RUNTIME_API_KEY=change-me-to-match-host-agent

# For manual mode (direct connection to a running Runtime Node)
# RUNTIME_ENDPOINT=http://windows-vm-ip:18081
# RUNTIME_API_KEY=change-me

# Core paths
WORKSPACE_ROOT=/app/workspaces
DB_PATH=/app/data/database.db
CACHE_ROOT=/app/cache
AUDIT_LOG_PATH=/app/logs/audit.log
LOG_LEVEL=info

# API File Server
API_ENABLED=true
API_PORT=18080
API_STORAGE_ROOT=/app/storage
# API_KEY=your-secret-key-here
