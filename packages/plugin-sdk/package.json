{
  "name": "@rikune/plugin-sdk",
  "version": "1.0.0-beta.3",
  "description": "Plugin SDK for rikune — types and utilities for third-party plugin authors.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "cmd /d /s /c \"pushd ..\\.. && eslint packages/plugin-sdk/src --ext .ts && popd\"",
    "lint:fix": "cmd /d /s /c \"pushd ..\\.. && eslint packages/plugin-sdk/src --ext .ts --fix && popd\"",
    "test": "cmd /d /s /c \"pushd ..\\.. && node --experimental-vm-modules node_modules\\jest\\bin\\jest.js --runInBand tests\\unit\\packages\\plugin-sdk.test.ts && popd\""
  },
  "keywords": [
    "mcp",
    "plugin-sdk",
    "reverse-engineering",
    "decompiler"
  ],
  "license": "MIT",
  "peerDependencies": {
    "zod": "^3.0.0"
  }
}
