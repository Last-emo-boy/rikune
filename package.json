{
  "name": "rikune",
  "version": "1.0.0-beta.3",
  "description": "MCP server for Windows binary reverse engineering, PE triage, Ghidra-assisted analysis, and reconstruction workflows.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "rikune": "./bin/rikune.js",
    "rikune-docker": "./bin/rikune-docker.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "bin/",
    "CHANGELOG.md",
    "README_zh.md",
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.html",
    "src/plugins/kb-collaboration/data/*.json",
    "workers/frida_worker.py",
    "workers/rizin_preview_worker.py",
    "workers/static_worker.py",
    "workers/speakeasy_compat.py",
    "workers/requirements.txt",
    "workers/requirements-dynamic.txt",
    "workers/requirements-qiling.txt",
    "workers/yara_rules/*.yar",
    "src/plugins/**/workers/*.py",
    "src/plugins/ghidra/scripts/*.java",
    "src/plugins/ghidra/scripts/*.py",
    "src/plugins/ghidra/scripts/README.md",
    "src/plugins/static-triage/helpers/DotNetMetadataProbe/DotNetMetadataProbe.csproj",
    "src/plugins/static-triage/helpers/DotNetMetadataProbe/Program.cs",
    "requirements.txt",
    "COPILOT_INSTALLATION.md",
    "src/plugins/frida/scripts/**/*.js",
    "src/plugins/frida/scripts/README.md"
  ],
  "scripts": {
    "build": "turbo run build && tsc && npm run copy-static",
    "build:shared": "turbo run build --filter=@rikune/shared",
    "build:runtime": "turbo run build --filter=@rikune/runtime-node",
    "build:host-agent": "turbo run build --filter=@rikune/windows-host-agent",
    "copy-static": "node -e \"const fs=require('fs'),p=require('path');const s='src/api/dashboard',d='dist/api/dashboard';fs.mkdirSync(d,{recursive:true});fs.readdirSync(s).forEach(f=>fs.copyFileSync(p.join(s,f),p.join(d,f)));\"",
    "clean": "node -e \"const fs=require('fs'); for (const p of ['dist']) { fs.rmSync(p,{recursive:true,force:true}); }\"",
    "dev": "tsx watch src/index.ts",
    "dev:dashboard": "node -e \"const fs=require('fs'),p=require('path');const s='src/api/dashboard',d='dist/api/dashboard';fs.mkdirSync(d,{recursive:true});const cp=()=>{fs.readdirSync(s).forEach(f=>fs.copyFileSync(p.join(s,f),p.join(d,f)));console.log('Dashboard copied',new Date().toLocaleTimeString())};cp();fs.watch(s,{recursive:true},cp)\"",
    "start": "node dist/index.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "typecheck": "turbo run typecheck",
    "validate": "npm run build && npm run lint && npm test",
    "lint": "eslint src packages/*/src --ext .ts",
    "lint:fix": "eslint src packages/*/src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"packages/*/src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"packages/*/src/**/*.ts\"",
    "prepack": "npm run build",
    "pack:dry-run": "npm pack --dry-run",
    "release:check": "npm run build && npm pack --dry-run",
    "docker:build": "npm run build && npm run docker:generate && docker compose -f docker-compose.yml build mcp-server",
    "docker:build:static": "npm run build && npm run docker:generate:static && docker compose -f docker-compose.analyzer.yml build analyzer",
    "docker:build:hybrid": "npm run build && npm run docker:generate:hybrid && docker compose -f docker-compose.hybrid.yml build analyzer",
    "docker:generate": "node scripts/generate-docker.mjs --profile=full",
    "docker:generate:static": "node scripts/generate-docker.mjs --profile=static",
    "docker:generate:hybrid": "node scripts/generate-docker.mjs --profile=hybrid",
    "docker:generate:all": "node scripts/generate-docker.mjs --all-profiles",
    "docker:generate:minimal": "node scripts/generate-docker.mjs --profile=static --exclude=ghidra,retdec,memory-forensics",
    "docker:generate:full": "node scripts/generate-docker.mjs --profile=full",
    "docs:api": "node scripts/generate-api-docs.js",
    "docker:up:static": "npm run build && npm run docker:generate:static && docker compose -f docker-compose.analyzer.yml up -d analyzer",
    "docker:up:full": "npm run build && npm run docker:generate && docker compose -f docker-compose.yml up -d mcp-server",
    "docker:up:hybrid": "npm run build && npm run docker:generate:hybrid && docker compose -f docker-compose.hybrid.yml up -d analyzer",
    "docker:run": "docker run --rm -it rikune:latest bash",
    "docker:test": "docker run --rm --entrypoint /usr/local/bin/validate-docker-full-stack.sh rikune:latest",
    "docker:clean": "docker system prune -af && docker builder prune -af",
    "docker:push": "docker push rikune:latest"
  },
  "keywords": [
    "mcp",
    "reverse-engineering",
    "decompiler",
    "pe-analysis",
    "malware-analysis",
    "ghidra",
    "windows",
    "copilot",
    "codex"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Last-emo-boy/rikune.git"
  },
  "homepage": "https://github.com/Last-emo-boy/rikune",
  "bugs": {
    "url": "https://github.com/Last-emo-boy/rikune/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@rikune/plugin-sdk": "1.0.0-beta.3",
    "better-sqlite3": "^12.6.2",
    "node-windows": "^1.0.0-beta.8",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "uuid": "^13.0.0",
    "yaml": "^2.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "fast-check": "^4.6.0",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@10.9.0"
}
