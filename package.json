{
  "name": "rikune",
  "version": "1.0.0-beta.3",
  "description": "MCP server for Windows binary reverse engineering, PE triage, Ghidra-assisted analysis, and reconstruction workflows.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "rikune": "./bin/rikune.js",
    "rikune-docker": "./bin/rikune-docker.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "bin/",
    "CHANGELOG.md",
    "README_zh.md",
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.html",
    "src/plugins/kb-collaboration/data/*.json",
    "workers/frida_worker.py",
    "workers/rizin_preview_worker.py",
    "workers/static_worker.py",
    "workers/speakeasy_compat.py",
    "workers/requirements.txt",
    "workers/requirements-dynamic.txt",
    "workers/requirements-qiling.txt",
    "workers/yara_rules/*.yar",
    "src/plugins/**/workers/*.py",
    "src/plugins/ghidra/scripts/*.java",
    "src/plugins/ghidra/scripts/*.py",
    "src/plugins/ghidra/scripts/README.md",
    "src/plugins/static-triage/helpers/DotNetMetadataProbe/DotNetMetadataProbe.csproj",
    "src/plugins/static-triage/helpers/DotNetMetadataProbe/Program.cs",
    "requirements.txt",
    "COPILOT_INSTALLATION.md",
    "src/plugins/frida/scripts/**/*.js",
    "src/plugins/frida/scripts/README.md"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:shared && tsc && npm run copy-static && npm run build:runtime && npm run build:host-agent",
    "build:shared": "cd packages/shared && npm run build",
    "copy-static": "node -e \"const fs=require('fs'),p=require('path');const s='src/api/dashboard',d='dist/api/dashboard';fs.mkdirSync(d,{recursive:true});fs.readdirSync(s).forEach(f=>fs.copyFileSync(p.join(s,f),p.join(d,f)));\"",
    "clean": "node -e \"const fs=require('fs'); for (const p of ['dist']) { fs.rmSync(p,{recursive:true,force:true}); }\"",
    "dev": "tsx watch src/index.ts",
    "dev:dashboard": "node -e \"const fs=require('fs'),p=require('path');const s='src/api/dashboard',d='dist/api/dashboard';fs.mkdirSync(d,{recursive:true});const cp=()=>{fs.readdirSync(s).forEach(f=>fs.copyFileSync(p.join(s,f),p.join(d,f)));console.log('Dashboard copied',new Date().toLocaleTimeString())};cp();fs.watch(s,{recursive:true},cp)\"",
    "start": "node dist/index.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "validate": "npm run build && npm run lint && npm test",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepack": "npm run build",
    "pack:dry-run": "npm pack --dry-run",
    "release:check": "npm run build && npm pack --dry-run",
    "docker:build": "docker build -t rikune:latest .",
    "docker:generate": "node scripts/generate-docker.mjs",
    "build:runtime": "cd packages/runtime-node && npm run build",
    "build:host-agent": "cd packages/windows-host-agent && npm run build",
    "docker:generate:minimal": "node scripts/generate-docker.mjs --exclude=ghidra,docker-backends,memory-forensics,dynamic",
    "docker:generate:full": "node scripts/generate-docker.mjs",
    "docs:api": "node scripts/generate-api-docs.js",
    "docker:run": "docker run --rm -it rikune:latest bash",
    "docker:test": "docker run --rm --entrypoint /usr/local/bin/validate-docker-full-stack.sh rikune:latest",
    "docker:clean": "docker system prune -af && docker builder prune -af",
    "docker:push": "docker push rikune:latest"
  },
  "keywords": [
    "mcp",
    "reverse-engineering",
    "decompiler",
    "pe-analysis",
    "malware-analysis",
    "ghidra",
    "windows",
    "copilot",
    "codex"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Last-emo-boy/rikune.git"
  },
  "homepage": "https://github.com/Last-emo-boy/rikune",
  "bugs": {
    "url": "https://github.com/Last-emo-boy/rikune/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.6.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "uuid": "^13.0.0",
    "yaml": "^2.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "fast-check": "^4.6.0",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
