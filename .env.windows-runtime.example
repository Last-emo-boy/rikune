# Rikune Windows Runtime Environment
# Copy this file to .env.runtime-windows and adjust values for your setup.

# Host Agent settings
HOST_AGENT_PORT=18082
HOST_AGENT_API_KEY=change-me-to-a-random-32-char-string
HOST_AGENT_WORKSPACE=C:\Rikune\Runtime

# Optional: restrict CORS origin for Runtime Node (distributed mode)
# RUNTIME_CORS_ORIGIN=http://your-linux-analyzer-ip:18080

# Optional: allow unsafe runtime outside Windows Sandbox (DANGEROUS — only for dev)
# ALLOW_UNSAFE_RUNTIME=true
